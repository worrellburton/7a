# ------------------------------------------------------------
# Copy this file to .env.local and fill in the values.
# .env* is gitignored — these values must never be committed.
# ------------------------------------------------------------

# Supabase — project URL + public anon key (safe for the browser).
# Found under Project Settings → API → Project URL / anon public.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — service-role key (server-only). Used by /api/upload to
# write storage objects and by any admin-only server task. Never expose
# this to the browser.
# Found under Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=

# CallTrackingMetrics — base64-encoded "account_id:api_key" for basic auth.
# Used by /api/ctm.
CTM_API_TOKEN=

# Optional: CTM account id. If unset, /api/ctm/sync discovers it via
# /accounts.json on every run.
CTM_ACCOUNT_ID=

# Shared secret used by Vercel Cron to authorize /api/ctm/sync. Generate
# a random string and set the same value in Vercel project env.
CRON_SECRET=

# Shared token for the CTM → /api/ctm/webhook endpoint. Configure CTM's
# "Call Completed" webhook URL as:
#   https://<your-app>/api/ctm/webhook?token=<CTM_WEBHOOK_TOKEN>
# Generate with `openssl rand -hex 32`.
CTM_WEBHOOK_TOKEN=

# Stedi — professional claims API key. Used by /api/stedi.
STEDI_API_KEY=

# Google — client-side tracking tags on the public site.
# Pick whichever matches how you tag the site. If you use GTM you do NOT
# also need the GA4 measurement ID here (GTM fires GA4 for you).
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GTM_ID=

# Google OAuth — one client covers GA4 Data API, Search Console, and
# Business Profile. Minted once via OAuth Playground as a Workspace admin
# (Internal app, so no verification needed, refresh token doesn't expire).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# Google — resource IDs for server-side reads.
# GA4 property (numeric, e.g. 412345678).
GA4_PROPERTY_ID=
# Search Console site. Use "sc-domain:example.com" for Domain properties
# or the exact "https://example.com/" for URL-prefix properties.
GSC_SITE_URL=

# Google Places API key — server-only. Powers the live Google reviews
# widgets and the Maps business-listing card (NAP, hours, link to the
# Google Maps listing). Restrict the key to the Places API only; leave
# Application restrictions at "None" since Vercel serverless functions
# don't have a stable IP. Never expose to the browser.
GOOGLE_PLACES_API_KEY=

# Google Maps JS API key — used by /app/outreach for the Map view that
# pins each contact at their geocoded location, and by the Location
# autocomplete dropdown (server-side proxy reuses GOOGLE_PLACES_API_KEY,
# but the browser map render needs a public key). The same Google
# Cloud project that powers GOOGLE_PLACES_API_KEY should work; just
# enable the Maps JavaScript API on it. Restrict the key by HTTP
# referrer to the production domain(s). Falls back to
# NEXT_PUBLIC_GOOGLE_MAPS_EMBED_API_KEY when unset so dev environments
# can reuse the single-pin embed key without a separate config step.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Google Gemini — powers call-recording analysis in /app/calls (the
# summary / operator strengths / fit score / sentiment fields). Key
# comes from https://aistudio.google.com/app/apikey (this is a
# different system from GCP Console — don't reuse your Places key).
# Without this, /api/claude/calls/score returns 502 and calls stay
# stuck at needs_score=true.
GEMINI_API_KEY=
# Optional override. Defaults to gemini-2.5-pro when unset.
GEMINI_MODEL=gemini-2.5-pro

# PageSpeed Insights — optional. Powers the Core Web Vitals score in
# /app/seo/audit. Without this, the perf category is skipped (other
# audits still run). Get a key at:
# https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=

# OpenAI — powers the ChatGPT engine in /app/geo/audit. Without this
# the OpenAI engine is skipped; the audit still runs against the
# other engines. Key from https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Optional. Defaults to gpt-4o-mini-search-preview for cost; override
# to gpt-4o-search-preview for higher quality at ~4x the token cost.
OPENAI_SEARCH_MODEL=

# Perplexity — powers the Perplexity engine in /app/geo/audit. The
# cheapest way to sample a grounded AI answer (~$0.001/request on
# `sonar`). Key from https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=
# Optional. Defaults to `sonar`. `sonar-pro` is ~8x the cost for
# deeper research answers.
PERPLEXITY_MODEL=

# SerpAPI — powers the Google AI Overviews engine in /app/geo/audit.
# Google has no official AIO API, so we scrape via SerpAPI. Without
# this key, the Google AIO engine is skipped. Key from
# https://serpapi.com/dashboard (~$50/mo covers weekly audits).
SERPAPI_KEY=

# Anthropic — fallback scorer used when audio can't be downloaded
# from CallTrackingMetrics (metadata-only analysis).
ANTHROPIC_API_KEY=
# Optional override for the Claude model used in the fallback path.
ANTHROPIC_MODEL=

# Resend — transactional email. Used by /api/public/vob to email
# the admissions team when a VOB form is submitted. Server-only.
RESEND_API_KEY=
# Optional override for the "From" header. Defaults to
# "Seven Arrows Admissions <noreply@sevenarrowsrecoveryarizona.com>".
# Set this once your custom sending domain is verified in Resend.
RESEND_FROM=
# Comma-separated recipient list for VOB submissions. Defaults to
# admissions@sevenarrowsrecoveryarizona.com when unset.
RESEND_TO_VOB=

# ElevenLabs — text-to-speech for blog articles in /app/content.
# /api/content/[id]/audio uses xi-api-key to synthesize MP3s and
# uploads them to the `blog-audio` Supabase Storage bucket.
ELEVENLABS_API_KEY=
# Optional voice override. When unset, the route falls back to the
# "Rachelle" voice (ZT9u07TYPVl83ejeLakq) hardcoded in content-audio.ts.
ELEVENLABS_VOICE_ID=
# Optional model override. Defaults to eleven_multilingual_v2.
ELEVENLABS_MODEL_ID=

# Optional URL of the "Road to Recovery" intro music bumper. Played
# between the spoken intro ("Welcome to Seven Arrows Road to Recovery…")
# and the article narration. When unset, the audio jumps straight from
# the spoken intro into the body with no music sting.
BLOG_INTRO_MUSIC_URL=
